# Copy this file to `.env` and fill in your values.

# Required for AI fallback (used when an ingredient is not found locally
# nor in Open Food Facts). If left empty, the AI fallback returns zeros
# with confidence=0 instead of crashing.
OPENAI_API_KEY=

# Optional. Defaults to "gpt-4o-mini" if unset.
OPENAI_MODEL=gpt-4o-mini

# Optional. Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Auth (REQUIRED in production) ─────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty in development — a random secret is generated on every restart
# (that means all tokens are invalidated on restart, which is fine for dev).
JWT_SECRET=

# Optional. Defaults shown below.
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Cookie security (REQUIRED in production) ──────────────
# In production with HTTPS, frontend & backend on different domains:
#   COOKIE_SECURE=true
#   COOKIE_SAMESITE=none
# In local dev (HTTP localhost), the defaults below are correct.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Refresh-token cookie Path=. Default "/" — needed when the API is mounted under /_/backend/auth/* (e.g. Vercel).
# Only use AUTH_COOKIE_PATH=/auth if the browser requests /auth/* at the origin (local Vite proxy).
AUTH_COOKIE_PATH=/

# ── Sentry (optional, recommended in production) ──────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.2
