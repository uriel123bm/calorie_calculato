{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend",
      "framework": "fastapi"
    }
  },
  "crons": [
    {
      "path": "/_/backend/push/cron/vitamin-reminder",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/_/backend/push/cron/meal-reminder",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/_/backend/push/cron/water-reminder",
      "schedule": "30 17 * * *"
    },
    {
      "path": "/_/backend/push/cron/evening-reminder",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/_/backend/push/cron/weekly-summary",
      "schedule": "0 5 * * 0"
    }
  ]
}
