# Copy this file to `.env` (or set in your hosting provider) and adjust.

# Base URL of the FastAPI backend.
# - In local dev leave it empty; Vite proxies /ingredients and /recipe to
#   http://localhost:8000 automatically.
# - In production point it to your deployed backend, e.g.:
#     VITE_API_BASE=https://your-backend.example.com
VITE_API_BASE=

# Optional Sentry DSN for frontend error tracking
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional PostHog — signup funnel (client) + same key on backend as POSTHOG_API_KEY
# EU stack (recommended from Israel): https://eu.posthog.com — same region as POSTHOG_HOST
VITE_POSTHOG_HOST=https://eu.i.posthog.com
VITE_POSTHOG_KEY=
